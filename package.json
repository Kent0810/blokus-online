{
  "name": "blockus",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run build --workspace @blockus/shared",
    "dev": "npm-run-all --parallel dev:*",
    "dev:backend": "npm run dev --workspace @blockus/backend",
    "dev:frontend": "npm run dev --workspace @blockus/frontend",
    "ngrok": "bash start-tunnel.sh",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
